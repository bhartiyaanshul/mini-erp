# Copy this file to .env and fill in real values:  cp .env.example .env
# The real .env is gitignored and must never be committed.

# Database connection string.
# Default is a local SQLite file. Swap for a Postgres URL to scale,
# e.g. postgresql+psycopg://user:pass@host/db
# Note: avoid placing the SQLite file inside an iCloud/Dropbox-synced folder;
# sync can swap the file's inode and cause "readonly database" errors. Use an
# absolute path with 4 slashes if you need it outside the project dir, e.g.
# sqlite:////home/you/.local/share/mini-erp/mini_erp.db
DATABASE_URL=sqlite:///./mini_erp.db

# Auth — generate a strong random secret for any real deployment,
# e.g. python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Comma-separated list of allowed CORS origins (the frontend dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Predictive procurement: paste a Groq API key for the live AI briefing.
# Get one at https://console.groq.com/keys
# Leave blank to use the deterministic templated briefing — the feature works either way.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
